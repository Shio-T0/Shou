<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/ink">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="22dp"
            android:text="@string/settings_blurb"
            android:textColor="@color/paperDim"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3" />

        <EditText
            android:id="@+id/host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/host_hint"
            android:inputType="textUri"
            android:textColor="@color/paper"
            android:autofillHints="" />

        <EditText
            android:id="@+id/port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/port_hint"
            android:inputType="number"
            android:textColor="@color/paper"
            android:autofillHints="" />

        <EditText
            android:id="@+id/token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/token_hint"
            android:inputType="text"
            android:textColor="@color/paper"
            android:autofillHints="" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/https"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/use_https"
            android:textColor="@color/paper"
            android:textSize="15sp" />

        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/accent"
            android:text="@string/save"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
