<?xml version="1.0" encoding="utf-8"?>
<!-- One-cell-tall now-playing strip: cover · title + progress · transport. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_body"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <ImageView
        android:id="@+id/w_cover"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:scaleType="fitXY"
        android:src="@drawable/widget_cover_placeholder"
        android:contentDescription="@string/app_name" />

    <!-- Meta: title + status, then a thin progress bar with times. -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="11dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/w_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nothing playing"
                android:textColor="@color/paper"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/w_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/pill_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="IDLE"
                android:textColor="@color/paperDim"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/w_pos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/paperDim"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <ProgressBar
                android:id="@+id/w_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="7dp"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/widget_progress" />

            <TextView
                android:id="@+id/w_dur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/paperDim"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- Transport -->
    <ImageView
        android:id="@+id/w_prev"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/widget_btn"
        android:padding="7dp"
        android:src="@drawable/ic_media_prev"
        android:contentDescription="@string/cd_prev" />

    <ImageView
        android:id="@+id/w_play"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginHorizontal="7dp"
        android:background="@drawable/widget_btn_accent"
        android:padding="11dp"
        android:src="@drawable/ic_media_play"
        android:contentDescription="@string/cd_play" />

    <ImageView
        android:id="@+id/w_next"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/widget_btn"
        android:padding="7dp"
        android:src="@drawable/ic_media_next"
        android:contentDescription="@string/cd_next" />

    <ImageView
        android:id="@+id/w_wake"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="7dp"
        android:background="@drawable/widget_btn"
        android:padding="7dp"
        android:src="@drawable/ic_wake"
        android:contentDescription="@string/wake_pc" />
</LinearLayout>
