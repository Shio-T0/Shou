<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_body"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="朱 SHOU"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/w_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="Shou"
            android:textColor="@color/paperDim"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/w_wake"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/widget_btn"
            android:padding="8dp"
            android:src="@drawable/ic_wake"
            android:contentDescription="@string/wake_pc" />
    </LinearLayout>

    <TextView
        android:id="@+id/w_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Nothing playing"
        android:textColor="@color/paper"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/w_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Tap to open Shou"
        android:textColor="@color/paperDim"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/w_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/widget_btn"
            android:padding="9dp"
            android:src="@drawable/ic_media_prev"
            android:contentDescription="@string/cd_prev" />

        <ImageView
            android:id="@+id/w_play"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/widget_btn_accent"
            android:padding="13dp"
            android:src="@drawable/ic_media_play"
            android:contentDescription="@string/cd_play" />

        <ImageView
            android:id="@+id/w_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/widget_btn"
            android:padding="9dp"
            android:src="@drawable/ic_media_next"
            android:contentDescription="@string/cd_next" />
    </LinearLayout>
</LinearLayout>
