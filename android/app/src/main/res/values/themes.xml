<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Shou" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/ink</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:editTextColor">@color/paper</item>
        <item name="android:textColorHint">@color/paperDim</item>
    </style>

    <!-- Small uppercased caption above each input. -->
    <style name="FieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">7dp</item>
        <item name="android:textColor">@color/paperDim</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.09</item>
    </style>

    <!-- Rounded text inputs. -->
    <style name="Field">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:background">@drawable/bg_field</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:textColor">@color/paper</item>
        <item name="android:textColorHint">@color/paperDim</item>
        <item name="android:textSize">16sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:autofillHints"></item>
    </style>
</resources>
